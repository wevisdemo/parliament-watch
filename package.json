{
	"name": "parliament-watch",
	"version": "0.0.1",
	"private": true,
	"type": "module",
	"scripts": {
		"prepare": "husky install",
		"dev": "pnpm run gen:graphql && vite dev",
		"build": "pnpm run gen:graphql && vite build",
		"preview": "vite preview",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"lint": "ESLINT_USE_FLAT_CONFIG=true eslint --fix .",
		"format": "prettier --write .",
		"test": "vitest",
		"sass:build": "sass --load-path=node_modules --style=compressed --no-source-map src/styles/carbon/index.scss src/styles/carbon/pre-compiled.css",
		"story:dev": "histoire dev",
		"story:build": "HISTOIRE_BASE=/stories/ histoire build",
		"story:preview": "histoire preview",
		"gen:graphql": "genql --endpoint https://politigraph.wevis.info/graphql --output src/lib/politigraph/genql -S Date:string -S DateTime:string",
		"gen:component": "hygen component new",
		"update:politician-ranking": "tsx src/lib/politician-ranking/run-update-job.ts"
	},
	"lint-staged": {
		"*.md": "doctoc --github --update-only",
		"*.{js,ts,svelte}": "eslint --fix",
		"*": "prettier --write --ignore-unknown"
	},
	"dependencies": {
		"@genql/cli": "^6.3.3",
		"@melt-ui/svelte": "^0.86.6",
		"@sveltejs/adapter-static": "^3.0.10",
		"@sveltejs/kit": "^2.65.2",
		"@wevisdemo/ui": "^7.0.2",
		"autoprefixer": "^10.4.14",
		"carbon-components": "^10.58.10",
		"carbon-components-svelte": "^0.109.0",
		"carbon-icons-svelte": "^13.12.0",
		"cloudflare": "^5.2.0",
		"d3": "^7.8.5",
		"d3-array": "^3.2.4",
		"d3-dsv": "^3.0.1",
		"d3-scale-chromatic": "^3.1.0",
		"d3-shape": "^3.2.0",
		"dayjs": "^1.11.10",
		"fastest-levenshtein": "^1.0.16",
		"keen-slider": "^6.8.6",
		"pino": "^8.19.0",
		"pino-pretty": "^10.3.1",
		"postcss": "^8.4.27",
		"sass": "^1.67.0",
		"scrollama": "^3.2.0",
		"sheethuahua": "^3.1.0",
		"svelte": "^5.56.3",
		"tailwind-merge": "^2.1.0",
		"tailwindcss": "^3.3.3",
		"tslib": "^2.4.1",
		"tsx": "^4.7.0",
		"typescript": "^5.0.0",
		"vite-plugin-devtools-json": "^1.0.0",
		"vitest": "^4.1.9"
	},
	"devDependencies": {
		"@commitlint/cli": "^17.7.0",
		"@commitlint/config-conventional": "^17.7.0",
		"@eslint/js": "^8.57.1",
		"@histoire/plugin-svelte": "https://pkg.pr.new/histoire-dev/histoire/@histoire/plugin-svelte@607e09e87a278ede3c5ce2f733c21c5f8e1545f9",
		"@sveltejs/vite-plugin-svelte": "^7.1.2",
		"@trivago/prettier-plugin-sort-imports": "^4.3.0",
		"@types/d3": "^7.4.1",
		"@types/d3-array": "^3.2.2",
		"@types/d3-dsv": "^3.0.7",
		"@types/d3-scale-chromatic": "^3.1.0",
		"@types/d3-shape": "^3.1.8",
		"@types/md5": "^2.3.5",
		"@types/node": "^24.12.0",
		"@typescript-eslint/eslint-plugin": "^7.18.0",
		"@typescript-eslint/parser": "^7.18.0",
		"doctoc": "^2.2.1",
		"eslint": "^8.57.0",
		"eslint-config-prettier": "^9.1.0",
		"eslint-plugin-svelte": "^3.19.0",
		"globals": "^17.6.0",
		"histoire": "https://pkg.pr.new/histoire-dev/histoire/histoire@607e09e87a278ede3c5ce2f733c21c5f8e1545f9",
		"husky": "^8.0.3",
		"hygen": "^6.2.11",
		"lint-staged": "^13.2.3",
		"prettier": "^3.2.5",
		"prettier-plugin-svelte": "^4.1.1",
		"prettier-plugin-tailwindcss": "^0.7.2",
		"svelte-check": "^4.6.0",
		"svelte-eslint-parser": "^1.8.0",
		"typescript-eslint": "^8.61.1",
		"vite": "^8.0.16"
	},
	"packageManager": "pnpm@10.25.0"
}
